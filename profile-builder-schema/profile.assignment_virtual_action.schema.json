{
  "type": "object",
  "title": "Virtual Action",
  "description": "A virtual control action",
  "properties": {
    "type": {
      "enum": ["virtual"]
    },
    "control": {
      "type": "string",
      "description": "The name of the virtual control to update. Should start with 'virtual:' for clear segmentation",
      "examples": ["virtual:Button1"],
      "pattern": "^virtual:"
    },
    "value": {
      "type": "number"
    }
  },
  "required": ["type", "control", "value"]
}
